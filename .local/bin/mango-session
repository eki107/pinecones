#!/bin/sh

export GBM_BACKEND=nvidia-drm
export __GLX_VENDOR_LIBRARY_NAME=nvidia
export WLR_RENDERER=vulkan

export XDG_SESSION_TYPE=wayland
export XDG_CURRENT_DESKTOP=wlroots

# Wayland-native toolkit hints
# https://docs.voidlinux.org/config/graphical-session/wayland.html#native-applications
export QT_QPA_PLATFORM=wayland
export GDK_BACKEND=wayland
export SDL_VIDEODRIVER=wayland
export CLUTTER_BACKEND=wayland
export ELM_DISPLAY=wl
export _JAVA_AWT_WM_NONREPARENTING=1
# export WAYLAND_DISPLAY=wayland-1

# https://docs.voidlinux.org/config/session-management.html#xdg_runtime_dir
export XDG_RUNTIME_DIR=/run/user/$(id -u)


# PRETTIES
swaybg -i '/home/stefan/.local/share/wallpapers/Pacifico, 2025 Desktop Wallpaper.jpg' &

# music services 
pipewire &
mpd &

# run mango in dbus session 
# mentioned in void handbook 
# https://docs.voidlinux.org/config/session-management.html#d-bus
exec dbus-run-session mango
